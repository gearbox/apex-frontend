{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "apex-vex-staging",
  "compatibility_date": "2026-04-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": "./build",
    "not_found_handling": "single-page-application",
  },
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  }
}
